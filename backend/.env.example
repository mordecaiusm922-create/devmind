# ── Required ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── API Keys (comma-separated, no spaces) ────────────────────────────────────
# Generate strong keys: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=your-api-key-here

# ── GitHub Webhook ─────────────────────────────────────────────────────────────
# Set this when configuring the webhook in your GitHub repo settings
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=https://your-frontend-domain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_S=60

# ── Timeouts ──────────────────────────────────────────────────────────────────
ANALYSIS_TIMEOUT_S=120
